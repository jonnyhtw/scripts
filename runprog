#!/usr/bin/env bash

# Optimized runprog script for ARCHER2
# Handles: u-dx690/run25, u-dx690 run25, u-dx690 25

# 1. Clean up inputs
suite_part=${1%/}  # Remove trailing slash

if [[ -z $2 ]]; then
    export workflow="$suite_part"
else
    # Remove "run" prefix if typed, then add it back cleanly
    run_part=${2#run}
    export workflow="${suite_part}/run${run_part}"
fi

# 2. Set directory path
target_dir="$HOME/cylc-run/$workflow/work"

if [ ! -d "$target_dir" ]; then
    echo "---> Error: Directory $target_dir not found <---"
    exit 1
fi

cd "$target_dir" || exit

# 3. Find the latest cycle point (e.g., 18500101T0000Z)
# Sort newest first
latest_cycle_point=$(ls -d ????????T????Z 2>/dev/null | sort -r | head -n 1)

if [[ ${#latest_cycle_point} -eq 14 ]]; then

    for dir in "$latest_cycle_point"/{atmos*,coupled*,*fcst*}; do

        if [ -d "$dir/pe_output" ]; then
            echo "task name is -------> $(basename "$dir")"
            
            # 4. Search the master PE output file (usually ends in 0)
            # Using grep on the whole file to ensure we don't miss the line,
            # but restricted to files ending in 0 to keep it fast.
            last_stat=$(grep -sh 'Atm_Step: Timestep' "$dir"/pe_output/*0 2>/dev/null | tail -n 1)
            
            if [[ -n "$last_stat" ]]; then
                echo "$last_stat"
            else
                echo "      (Timestep info not found in pe_output/*0)"
            fi
        fi

    done

else
    echo "---> no matching datetime cycle points found in $workflow <---"
fi
